{
  "name": "secretshop-static",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:catalog": "python scripts/build-product-families.py && node scripts/build-marketplace-catalog.mjs && node scripts/build-affiliate-links.mjs",
    "test": "node --test tests/*.test.mjs scripts/import-awin.test.mjs",
    "test:browser": "node tests/browser-smoke.mjs",
    "validate:catalog": "node scripts/validate-catalog.mjs && node scripts/audit-affiliate-links.mjs",
    "validate:site": "node scripts/check-site.mjs",
    "quality": "npm run build:catalog && npm test && npm run validate:catalog && npm run validate:site",
    "quality:full": "npm run quality && npm run test:browser",
    "amazon:links": "node scripts/build-amazon-links.mjs",
    "amazon:import:dry": "node scripts/import-amazon-products.mjs --dry-run",
    "amazon:import": "node scripts/import-amazon-products.mjs && npm run quality"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "python": ">=3.10"
  },
  "devDependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "axe-core": "^4.12.1",
    "playwright": "^1.61.1",
    "vite": "^8.1.5"
  }
}
